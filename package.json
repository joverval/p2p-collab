{
  "name": "@joverval/p2p-collab",
  "version": "0.1.0",
  "description": "Browser-to-browser P2P collaboration library using WebRTC data channels and URL-encoded SDP signaling. No servers required.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "webrtc",
    "p2p",
    "peer-to-peer",
    "collaboration",
    "data-channel",
    "simple-peer",
    "browser",
    "typescript"
  ],
  "author": "Joaquín Vergara",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joverval/p2p-collab"
  },
  "dependencies": {
    "simple-peer": "^9.11.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}